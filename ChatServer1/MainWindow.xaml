<Window x:Class="ChatServer1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Чат - Сервер" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Порт:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>
                <TextBox x:Name="PortBox" Text="5000" Width="60" Margin="0,0,10,0" Background="White"/>
                <Button x:Name="StartBtn" Content="Запустить сервер" Click="StartBtn_Click" Width="120" Margin="0,0,5,0"
                        Background="#27AE60" Foreground="White" BorderThickness="0" Padding="5"/>
                <Button x:Name="StopBtn" Content="Остановить" Click="StopBtn_Click" Width="100" IsEnabled="False"
                        Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="5"/>
                <TextBlock x:Name="StatusText" Text="⛔ Сервер не запущен" VerticalAlignment="Center" Foreground="#E74C3C" Margin="20,0,0,0"/>
                <TextBlock x:Name="IpText" Text="" VerticalAlignment="Center" 
                        Foreground="LightCyan" Margin="15,0,0,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <ListBox x:Name="LogListBox" Grid.Row="1" FontFamily="Consolas" FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StatusBar Grid.Row="2" Background="#ECF0F1">
            <StatusBarItem>
                <TextBlock x:Name="ClientsCountText" Text="Подключено клиентов: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>