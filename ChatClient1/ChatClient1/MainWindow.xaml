<Window x:Class="ChatClient1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Чат - Клиент" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#34495E" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="IP:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>
                <TextBox x:Name="IpBox" Text="127.0.0.1" Width="100" Margin="0,0,10,0"/>
                <TextBlock Text="Порт:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>
                <TextBox x:Name="PortBox" Text="5000" Width="60" Margin="0,0,10,0"/>
                <TextBlock Text="Ник:" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>
                <TextBox x:Name="NickBox" Text="User" Width="100" Margin="0,0,10,0"/>
                <Button x:Name="ConnectBtn" Content="Подключиться" Click="ConnectBtn_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Padding="8,4"/>
                <Button x:Name="DisconnectBtn" Content="Отключиться" Click="DisconnectBtn_Click" IsEnabled="False" Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="8,4" Margin="5,0,0,0"/>
                <TextBlock x:Name="ConnectionStatus" Text="⛔ Отключён" VerticalAlignment="Center" Foreground="#E74C3C" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessagesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5,2,5,2" CornerRadius="8" Padding="8,4" Background="{Binding Background}" HorizontalAlignment="{Binding Alignment}" MaxWidth="400">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="12" Foreground="{Binding NameColor}"/>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13"/>
                                <TextBlock Text="{Binding Time}" FontSize="10" Foreground="Gray" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" Background="#F0F3F4" Margin="10,0,0,0" CornerRadius="8" BorderBrush="#BDC3C7" BorderThickness="1">
            <DockPanel Margin="5">
                <TextBlock Text="👥 Онлайн" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,5" FontSize="14"/>
                <ListBox x:Name="UsersListBox" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Ellipse Width="10" Height="10" Fill="Green" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0" CornerRadius="8" Padding="5" Background="#ECF0F1">
            <DockPanel>
                <Button x:Name="SendBtn" Content="📤 Отправить" Click="SendBtn_Click" Width="80" DockPanel.Dock="Right" Background="#3498DB" Foreground="White" BorderThickness="0" Margin="5,0,0,0"/>
                <TextBox x:Name="MessageInputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="30" MaxHeight="100" VerticalScrollBarVisibility="Auto" KeyDown="MessageInputBox_KeyDown"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>